{
  "Jellyking": {
    "Server": {
      "Host": "0.0.0.0",
      "Port": 5656
    },
    "Detection": {
      "TargetHost": "localhost",
      "IntervalSeconds": 5,
      "TimeoutMs": 2000
    },
    "Ui": {
      "Theme": "dark",
      "Title": "Jellyking"
    },
    "Security": {
      "UseHttps": false,
      "HttpPort": 5656,
      "HttpsPort": 5657,
      "CertPath": null,
      "CertPassword": null,
      "Hsts": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Yarp": "Warning"
      }
    }
  }
}